@* dotnet/src/TelemetryPoc.App/Components/Gauge.razor *@
<div class="gauge">
  <svg viewBox="-50 -50 100 100" width="120" height="120">
    <circle cx="0" cy="0" r="46" class="gauge-face" />
    <g transform="rotate(@Angle.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))">
      <line x1="0" y1="0" x2="0" y2="-38" class="gauge-needle" />
    </g>
    <circle cx="0" cy="0" r="3" class="gauge-hub" />
    <text x="0" y="30" text-anchor="middle" class="gauge-label">@Label</text>
    <text x="0" y="42" text-anchor="middle" class="gauge-value">@Value.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) @Unit</text>
  </svg>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Unit { get; set; } = "";
    [Parameter] public double Value { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; }

    private double Angle
    {
        get
        {
            if (Max <= Min) return -120;
            var t = Math.Clamp((Value - Min) / (Max - Min), 0, 1);
            return -120 + t * 240;
        }
    }
}
