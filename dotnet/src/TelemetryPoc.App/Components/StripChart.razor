@* dotnet/src/TelemetryPoc.App/Components/StripChart.razor *@
@* ScottPlot core renders to a PNG (SkiaSharp, headless) shown as an <img>.        *@
@* ScottPlot.Blazor's BlazorPlot is WASM-only ([JSImport]) and throws under         *@
@* Blazor Hybrid / BlazorWebView, so we render server-side and stream the image.    *@
<div class="strip-chart">
  <div class="strip-title">@Title</div>
  @if (_imgB64 is not null)
  {
    <img class="strip-img" src="data:image/png;base64,@_imgB64" alt="@Title" />
  }
</div>

@code {
    public sealed record StripLine(string Label, IReadOnlyList<long> Xs, IReadOnlyList<double> Ys);

    [Parameter] public string Title { get; set; } = "";
    [Parameter] public IReadOnlyList<StripLine> Lines { get; set; } = Array.Empty<StripLine>();

    private readonly ScottPlot.Plot _plot = new();
    private string? _imgB64;
    private const int RenderWidth = 1000;
    private const int RenderHeight = 280;

    public void RefreshData()
    {
        _plot.Clear();
        foreach (var line in Lines)
        {
            if (line.Xs.Count == 0) continue;
            var xs = new double[line.Xs.Count];
            for (int i = 0; i < xs.Length; i++) xs[i] = line.Xs[i] / 1000.0; // ms -> sec
            var ys = line.Ys.ToArray();
            _plot.Add.Scatter(xs, ys);
        }
        byte[] png = _plot.GetImageBytes(RenderWidth, RenderHeight);
        _imgB64 = Convert.ToBase64String(png);
        StateHasChanged();
    }
}
