@* dotnet/src/TelemetryPoc.App/Components/ParamTable.razor *@
@using TelemetryPoc.Core
<table class="param-table">
  <thead><tr><th>Parameter</th><th>Eng. Data</th><th>Bar</th><th>Addr</th></tr></thead>
  <tbody>
    @foreach (var ch in Store.Channels)
    {
      var v = Store.Latest(ch.Id);
      var text = v is null ? "" : ValueFormat.FormatValue(ch, v.Value, Store.EnumIndex);
      var frac = (v is null || ch.Max <= ch.Min) ? 0.0 : Math.Clamp((v.Value - ch.Min) / (ch.Max - ch.Min), 0, 1);
      var color = (ch.Type == "enum" && v is not null)
        ? ValueFormat.SeverityColor(ValueFormat.DecodeEnum(ch.Id, v.Value, Store.EnumIndex)?.Severity)
        : "#2a7";
      <tr>
        <td class="name">@ch.Name</td>
        <td class="value">@text</td>
        <td class="bar"><div class="bar-fill" style="width:@(frac*100)%;background:@color"></div></td>
        <td class="addr">@ch.Addr</td>
      </tr>
    }
  </tbody>
</table>

@code {
    [Parameter, EditorRequired] public TelemetryStore Store { get; set; } = default!;
}
