<UserControl x:Class="TelemetryPoc.App.Views.WidgetGridView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TelemetryPoc.App.ViewModels"
             xmlns:views="using:TelemetryPoc.App.Views"
             Background="{StaticResource Bg}">
    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:GaugeViewModel"><views:GaugeView /></DataTemplate>
        <DataTemplate DataType="vm:LineChartViewModel"><views:LineChartView /></DataTemplate>
        <DataTemplate DataType="vm:MapWidgetViewModel"><views:MapWidgetView /></DataTemplate>
    </UserControl.DataTemplates>
    <ScrollViewer x:Name="Scroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                  DragDrop.AllowDrop="True" DragDrop.Drop="OnCanvasDrop" DragDrop.DragOver="OnCanvasDragOver">
        <Grid Width="1600" Height="1600">
        <ItemsControl ItemsSource="{Binding Widgets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas x:Name="GridCanvas" Width="1600" Height="1600" Background="Transparent" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.Styles>
                <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                </Style>
            </ItemsControl.Styles>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="{Binding Width}" Height="{Binding Height}" Margin="0"
                            Background="{StaticResource Panel}" BorderBrush="{StaticResource Border1}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- header: grip (drag-move) + controls -->
                            <Grid Grid.Row="0" Background="{StaticResource PanelHeader}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Grip" Grid.Column="0" Text="{Binding Name, StringFormat=☰ {0}}" Cursor="SizeAll"
                                           Foreground="{StaticResource PanelTitle}" FontSize="11" Padding="6,2"
                                           PointerPressed="OnHeaderDown" />
                                <Button Grid.Column="1" Content="{Binding ToggleLabel}" Click="OnToggle"
                                        IsVisible="{Binding IsToggleable}"
                                        Foreground="{StaticResource AccentCyan}" Background="{StaticResource Panel2}"
                                        BorderBrush="{StaticResource Border1}" BorderThickness="1"
                                        FontSize="9" Padding="6,2" Margin="2,2,4,2" Cursor="Hand" />
                                <Button Grid.Column="2" Content="✕" Click="OnRemove"
                                        IsVisible="{Binding IsRemovable}"
                                        Foreground="{StaticResource Red}" Background="Transparent" BorderThickness="0"
                                        FontSize="9" Padding="6,2" Cursor="Hand" />
                            </Grid>
                            <!-- body: content VM → implicit template -->
                            <ContentControl Grid.Row="1" Content="{Binding Content}"
                                            ContextRequested="OnWidgetContextRequested" />
                            <!-- resize grip, bottom-right -->
                            <Thumb x:Name="ResizeThumb" Grid.Row="1" Width="16" Height="16"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="BottomRightCorner"
                                   DragStarted="OnResizeStart" DragDelta="OnResizeDelta" DragCompleted="OnResizeCompleted">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Grid Background="Transparent">
                                            <!-- three diagonal grip lines, accent so the handle is obvious -->
                                            <Path Stroke="{StaticResource AccentCyan}" StrokeThickness="1.2" Opacity="0.9"
                                                  Data="M14,4 L4,14 M14,8 L8,14 M14,12 L12,14" />
                                        </Grid>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- drop/move placeholder: dashed ghost at the snapped target cell -->
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="DropGhost" IsVisible="False"
                       Stroke="{StaticResource AccentCyan}" StrokeThickness="1.5" StrokeDashArray="4,3"
                       Fill="#1538C5E0" RadiusX="3" RadiusY="3" />
        </Canvas>
        </Grid>
    </ScrollViewer>
</UserControl>
