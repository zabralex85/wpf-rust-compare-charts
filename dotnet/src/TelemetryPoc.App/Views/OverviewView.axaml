<UserControl x:Class="TelemetryPoc.App.Views.OverviewView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:TelemetryPoc.App.Views"
             Background="{StaticResource Bg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <views:ParamPanel Grid.Column="0" Margin="6" />
        <views:WidgetGridView Grid.Column="1" DataContext="{Binding Dashboard}" Margin="6" />
    </Grid>
</UserControl>
